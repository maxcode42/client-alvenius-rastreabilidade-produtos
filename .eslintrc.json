{
  "extends": [
    "eslint:recommended",
    "plugin:jest/recommended",
    "next/core-web-vitals",
    "prettier"
  ],
  "env": {
    "es2021": true,
    "browser": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "overrides": [
    {
      "files": ["tests/**/*.js", "tests/mocks/**/*.js", "infra/**/*.js"],
      "env": {
        "node": true,
        "jest": true
      }
    }
  ]
}
